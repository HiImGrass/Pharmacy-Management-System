<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="rootChiTietToa"
      prefHeight="550.0"
      prefWidth="850.0"
      spacing="12.0"
      style="-fx-background-color: #f8fafc; -fx-background-radius: 14; -fx-padding: 14;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.PharmacyManagement.gui.controller.ChiTietToaController">

    <children>
        <!-- HEADER -->
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="Chi tiết toa thuốc" textFill="#0f172a">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Label>
                        <Label text="Có thể sửa số lượng, đơn giá trực tiếp trong bảng" textFill="#64748b">
                            <font>
                                <Font size="12.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
                <Label text="Đang lập toa" textFill="#16a34a"
                       style="-fx-background-color: #dcfce7; -fx-background-radius: 999; -fx-padding: 6 12 6 12; -fx-font-weight: bold;" />
            </children>
        </HBox>

        <!-- TABLE CARD -->
        <VBox spacing="0.0"
              style="-fx-background-color: #ffffff; -fx-background-radius: 14; -fx-border-color: #e2e8f0; -fx-border-radius: 14; -fx-padding: 0; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.05), 10, 0, 0, 4);"
              VBox.vgrow="ALWAYS">
            <children>
                <TableView fx:id="tableChiTiet"
                           editable="true"
                           prefHeight="250.0"
                           style="-fx-background-color: #ffffff; -fx-control-inner-background: #ffffff; -fx-table-cell-border-color: #e5e7eb; -fx-border-color: transparent; -fx-background-radius: 14; -fx-text-background-color: #0f172a;"
                           VBox.vgrow="ALWAYS">
                    <placeholder>
                        <Label text="Chưa có thuốc trong toa" textFill="#94a3b8" />
                    </placeholder>
                    <columns>
                        <TableColumn fx:id="colTenThuoc" prefWidth="230.0" text="Tên thuốc" />
                        <TableColumn fx:id="colSoLuong" prefWidth="90.0" text="Số lượng" />
                        <TableColumn fx:id="colDonVi" prefWidth="85.0" text="Đơn vị" />
                        <TableColumn fx:id="colDonGia" prefWidth="150.0" text="Đơn giá" />
                        <TableColumn fx:id="colThanhTien" prefWidth="160.0" text="Thành tiền" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>

        <!-- TOTAL BAR -->
        <HBox alignment="CENTER_RIGHT"
              spacing="10.0"
              style="-fx-background-color: #eff6ff; -fx-background-radius: 14; -fx-border-color: #bfdbfe; -fx-border-radius: 14; -fx-padding: 14 16 14 16;">
            <children>
                <Label text="Tổng thành tiền" textFill="#1e3a8a">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblTongTien" text="0" textFill="#dc2626">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>
                <Label text="VND" textFill="#1e3a8a">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Label>
            </children>
        </HBox>
    </children>
</VBox>
