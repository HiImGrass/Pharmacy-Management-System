<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="750.0"
      prefWidth="1200.0"
      spacing="12.0"
      style="-fx-background-color: #f4f7fb; -fx-padding: 20;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.PharmacyManagement.gui.controller.NhapHangController">

    <children>
        <!-- HEADER -->
        <HBox alignment="CENTER_LEFT" spacing="16.0">
            <children>
                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="QUẢN LÝ NHẬP HÀNG" textFill="#0f172a">
                            <font>
                                <Font name="System Bold" size="26.0" />
                            </font>
                        </Label>
                        <Label text="Tạo phiếu nhập, quản lý thuốc nhập kho và in phiếu nhập" textFill="#64748b">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <Button fx:id="btnTaoToa"
                        mnemonicParsing="false"
                        onAction="#xuLyTaoToaMoi"
                        prefHeight="42.0"
                        prefWidth="170.0"
                        text="+ Tạo phiếu nhập"
                        textFill="#ffffff"
                        style="-fx-background-color: #2563eb; -fx-background-radius: 12; -fx-cursor: hand; -fx-font-weight: bold;" />
            </children>
        </HBox>

        <!-- MAIN CONTENT: chiếm toàn bộ phần trống còn lại -->
        <VBox minHeight="430.0"
              spacing="10.0"
              style="-fx-background-color: #ffffff; -fx-background-radius: 18; -fx-border-color: #e5e7eb; -fx-border-radius: 18; -fx-padding: 16;"
              VBox.vgrow="ALWAYS">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Danh sách phiếu nhập đang mở" textFill="#0f172a">
                                    <font><Font name="System Bold" size="17.0" /></font>
                                </Label>
                                <Label text="Mỗi tab tương ứng với một phiếu nhập riêng" textFill="#64748b">
                                    <font><Font size="12.0" /></font>
                                </Label>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <TabPane fx:id="tabPane"
                         minHeight="360.0"
                         prefHeight="600.0"
                         tabClosingPolicy="ALL_TABS"
                         style="-fx-background-color: #f8fafc; -fx-background-radius: 14; -fx-border-color: #e2e8f0; -fx-border-radius: 14;"
                         VBox.vgrow="ALWAYS" />
            </children>
        </VBox>

        <!-- FOOTER -->
        <HBox alignment="CENTER_RIGHT"
              spacing="12.0"
              style="-fx-background-color: #ffffff; -fx-background-radius: 16; -fx-border-color: #e5e7eb; -fx-border-radius: 16; -fx-padding: 12;">
            <children>
                <Label text="Sau khi kiểm tra danh sách thuốc nhập, bấm in phiếu nhập để lưu chứng từ."
                       textFill="#64748b"
                       HBox.hgrow="ALWAYS">
                    <font><Font size="13.0" /></font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="btnThanhToan"
                        text="In phiếu nhập"
                        mnemonicParsing="false"
                        onAction="#xuLyInHoaDon"
                        prefHeight="42.0"
                        prefWidth="150.0"
                        textFill="#ffffff"
                        style="-fx-background-color: #2563eb; -fx-background-radius: 12; -fx-cursor: hand; -fx-font-weight: bold;" />
            </children>
        </HBox>
    </children>
</VBox>
