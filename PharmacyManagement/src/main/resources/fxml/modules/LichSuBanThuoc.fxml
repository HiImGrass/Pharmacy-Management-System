<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="rootLichSuBanThuoc"
      prefHeight="650.0"
      prefWidth="900.0"
      spacing="18.0"
      style="-fx-background-color: #f4f7fb; -fx-padding: 24;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.PharmacyManagement.gui.controller.LichSuBanThuocController">

    <children>
        <!-- LIGHT THEME: soft white + blue/green accent -->
        <!-- HEADER -->
        <HBox alignment="CENTER_LEFT" spacing="16.0">
            <children>
                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="LỊCH SỬ BÁN HÀNG" textFill="#2563eb">
                            <font>
                                <Font name="System Bold" size="25.0" />
                            </font>
                        </Label>
                        <Label text="Tra cứu &amp; quản lý hóa đơn đã xuất" textFill="#64748b">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
            </children>
        </HBox>

        <!-- SUMMARY CARDS -->
        <HBox spacing="14.0">
            <children>
                <VBox prefHeight="115.0" prefWidth="180.0" spacing="10.0"
                      style="-fx-background-color: #ffffff; -fx-background-radius: 14; -fx-border-color: #e5e7eb; -fx-border-radius: 14; -fx-padding: 16; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.10), 14, 0, 0, 4);">
                    <children>
                        <Label text="TỔNG HÓA ĐƠN" textFill="#64748b">
                            <font>
                                <Font size="12.0" />
                            </font>
                        </Label>
                        <Label fx:id="lblTongHoaDon" text="0" textFill="#0f172a">
                            <font>
                                <Font name="System Bold" size="26.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <VBox prefHeight="115.0" prefWidth="180.0" spacing="10.0"
                      style="-fx-background-color: #ffffff; -fx-background-radius: 14; -fx-border-color: #bfdbfe; -fx-border-radius: 14; -fx-padding: 16; -fx-effect: dropshadow(gaussian, rgba(37,99,235,0.13), 14, 0, 0, 4);">
                    <children>
                        <Label text="DOANH THU" textFill="#64748b">
                            <font>
                                <Font size="12.0" />
                            </font>
                        </Label>
                        <Label fx:id="lblDoanhThu" text="0 đ" textFill="#2563eb">
                            <font>
                                <Font name="System Bold" size="25.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <VBox prefHeight="115.0" prefWidth="180.0" spacing="10.0"
                      style="-fx-background-color: #ffffff; -fx-background-radius: 14; -fx-border-color: #bbf7d0; -fx-border-radius: 14; -fx-padding: 16; -fx-effect: dropshadow(gaussian, rgba(22,163,74,0.13), 14, 0, 0, 4);">
                    <children>
                        <Label text="TRUNG BÌNH / ĐƠN" textFill="#64748b" wrapText="true">
                            <font>
                                <Font size="12.0" />
                            </font>
                        </Label>
                        <Label fx:id="lblTrungBinhDon" text="0 đ" textFill="#16a34a">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <VBox prefHeight="115.0" prefWidth="180.0" spacing="10.0"
                      style="-fx-background-color: #ffffff; -fx-background-radius: 14; -fx-border-color: #fde68a; -fx-border-radius: 14; -fx-padding: 16; -fx-effect: dropshadow(gaussian, rgba(245,158,11,0.14), 14, 0, 0, 4);">
                    <children>
                        <Label text="HÔM NAY" textFill="#64748b">
                            <font>
                                <Font size="12.0" />
                            </font>
                        </Label>
                        <Label fx:id="lblHomNay" text="0" textFill="#f59e0b">
                            <font>
                                <Font name="System Bold" size="26.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
            </children>
        </HBox>

        <!-- FILTER BAR -->
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <TextField fx:id="txtSearch"
                           prefHeight="42.0"
                           prefWidth="230.0"
                           promptText="🔍  Tìm mã HĐ, tên khách"
                           style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-border-color: #93c5fd; -fx-border-width: 1.5; -fx-border-radius: 10; -fx-text-fill: #0f172a; -fx-prompt-text-fill: #94a3b8; -fx-padding: 0 12 0 12;" />

                <DatePicker fx:id="dpTuNgay"
                            prefHeight="42.0"
                            prefWidth="162.0"
                            promptText="dd/MM/yyyy"
                            style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-border-color: #cbd5e1; -fx-border-radius: 10; -fx-text-fill: #0f172a;" />

                <Label text="–" textFill="#64748b">
                    <font>
                        <Font size="18.0" />
                    </font>
                </Label>

                <DatePicker fx:id="dpDenNgay"
                            prefHeight="42.0"
                            prefWidth="162.0"
                            promptText="dd/MM/yyyy"
                            style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-border-color: #cbd5e1; -fx-border-radius: 10; -fx-text-fill: #0f172a;" />

                <Button fx:id="btnLamMoi"
                        mnemonicParsing="false"
                        onAction="#xuLyLamMoi"
                        prefHeight="42.0"
                        prefWidth="46.0"
                        text="↻"
                        textFill="#ffffff"
                        style="-fx-background-color: #2563eb; -fx-background-radius: 10; -fx-border-color: #2563eb; -fx-border-radius: 10; -fx-cursor: hand;">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Button>
            </children>
        </HBox>

        <Label fx:id="lblKetQua" text="0 kết quả" textFill="#64748b">
            <font>
                <Font size="13.0" />
            </font>
        </Label>

        <!-- TABLE -->
        <TableView fx:id="tableLichSuBanHang"
                   prefHeight="320.0"
                   style="-fx-background-color: #ffffff; -fx-control-inner-background: #ffffff; -fx-table-cell-border-color: #e5e7eb; -fx-border-color: #dbeafe; -fx-border-radius: 14; -fx-background-radius: 14; -fx-text-background-color: #0f172a; -fx-selection-bar: #dbeafe; -fx-selection-bar-non-focused: #eff6ff;"
                   VBox.vgrow="ALWAYS">
            <placeholder>
                <Label text="Không có hóa đơn bán hàng" textFill="#64748b" />
            </placeholder>
            <columns>
                <TableColumn fx:id="colStt" prefWidth="45.0" text="#" />
                <TableColumn fx:id="colMaHoaDon" prefWidth="145.0" text="MÃ HĐ" />
                <TableColumn fx:id="colKhachHang" prefWidth="150.0" text="KHÁCH HÀNG" />
                <TableColumn fx:id="colTongTien" prefWidth="135.0" text="TỔNG TIỀN" />
                <TableColumn fx:id="colNgayBan" prefWidth="135.0" text="NGÀY BÁN" />
                <TableColumn fx:id="colChiTiet" prefWidth="80.0" text="CHI TIẾT" />
            </columns>
        </TableView>

        <!-- FOOTER / PAGINATION -->
        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <children>
                <Label fx:id="lblPhanTrang" text="Hiển thị 0–0 trong 0 hóa đơn" textFill="#64748b" HBox.hgrow="ALWAYS">
                    <font>
                        <Font size="13.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <!-- <Button fx:id="btnTrangTruoc"
                        mnemonicParsing="false"
                        onAction="#xuLyTrangTruoc"
                        prefHeight="38.0"
                        prefWidth="42.0"
                        text="‹"
                        textFill="#334155"
                        style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-border-color: #cbd5e1; -fx-border-radius: 10; -fx-cursor: hand;">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Button>
                <Button fx:id="btnPage1"
                        mnemonicParsing="false"
                        onAction="#xuLyChonTrang1"
                        prefHeight="38.0"
                        prefWidth="42.0"
                        text="1"
                        textFill="#ffffff"
                        style="-fx-background-color: #2563eb; -fx-background-radius: 10; -fx-border-color: #1d4ed8; -fx-border-radius: 10; -fx-cursor: hand;">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
                <Button fx:id="btnPage2"
                        mnemonicParsing="false"
                        onAction="#xuLyChonTrang2"
                        prefHeight="38.0"
                        prefWidth="42.0"
                        text="2"
                        textFill="#475569"
                        style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-border-color: #cbd5e1; -fx-border-radius: 10; -fx-cursor: hand;">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
                <Label text="..." textFill="#64748b">
                    <font>
                        <Font size="15.0" />
                    </font>
                </Label>
                <Button fx:id="btnTrangCuoi"
                        mnemonicParsing="false"
                        onAction="#xuLyTrangCuoi"
                        prefHeight="38.0"
                        prefWidth="42.0"
                        text="4"
                        textFill="#475569"
                        style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-border-color: #cbd5e1; -fx-border-radius: 10; -fx-cursor: hand;">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
                <Button fx:id="btnTrangSau"
                        mnemonicParsing="false"
                        onAction="#xuLyTrangSau"
                        prefHeight="38.0"
                        prefWidth="42.0"
                        text="›"
                        textFill="#334155"
                        style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-border-color: #cbd5e1; -fx-border-radius: 10; -fx-cursor: hand;">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Button> -->
            </children>
        </HBox>
    </children>
</VBox>
