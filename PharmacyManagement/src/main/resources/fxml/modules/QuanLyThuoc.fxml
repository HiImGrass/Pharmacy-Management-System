<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="rootQuanLyThuoc"
      prefHeight="650.0"
      prefWidth="980.0"
      spacing="18.0"
      style="-fx-background-color: #f4f7fb; -fx-padding: 24;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.PharmacyManagement.gui.controller.QuanLyThuocController">

    <children>
        <!-- HEADER -->
        <HBox alignment="CENTER_LEFT" spacing="16.0">
            <children>
                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="QUẢN LÝ THUỐC" textFill="#1d4ed8">
                            <font>
                                <Font name="System Bold" size="26.0" />
                            </font>
                        </Label>
                        <Label text="Quản lý danh mục thuốc, tồn kho, giá bán và hạn sử dụng" textFill="#64748b">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <Button fx:id="btnNhapFile"
                        mnemonicParsing="false"
                        onAction="#xuLyNhapFile"
                        prefHeight="42.0"
                        prefWidth="120.0"
                        text="⇧  Nhập file"
                        textFill="#2563eb"
                        style="-fx-background-color: #eff6ff; -fx-background-radius: 10; -fx-border-color: #bfdbfe; -fx-border-radius: 10; -fx-border-width: 1.2; -fx-cursor: hand;">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>

                <Button fx:id="btnXuatFile"
                        mnemonicParsing="false"
                        onAction="#xuLyXuatFile"
                        prefHeight="42.0"
                        prefWidth="120.0"
                        text="⇩  Xuất file"
                        textFill="#ffffff"
                        style="-fx-background-color: #2563eb; -fx-background-radius: 10; -fx-border-color: #1d4ed8; -fx-border-radius: 10; -fx-border-width: 1.2; -fx-cursor: hand;">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
            </children>
        </HBox>

        <!-- SUMMARY CARDS -->
        <HBox spacing="14.0">
            <children>
                <VBox prefHeight="100.0" prefWidth="230.0" spacing="8.0" style="-fx-background-color: #ffffff; -fx-background-radius: 14; -fx-border-color: #dbeafe; -fx-border-radius: 14; -fx-padding: 16;">
                    <children>
                        <Label text="TỔNG MẶT HÀNG" textFill="#64748b">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Label>
                        <Label fx:id="lblTongMatHang" text="NaN" textFill="#0f172a">
                            <font>
                                <Font name="System Bold" size="25.0" />
                            </font>
                        </Label>
                        <Label text="Tổng mặt hàng đang có" textFill="#94a3b8">
                            <font>
                                <Font size="12.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <VBox prefHeight="100.0" prefWidth="230.0" spacing="8.0" style="-fx-background-color: #ffffff; -fx-background-radius: 14; -fx-border-color: #fed7aa; -fx-border-radius: 14; -fx-padding: 16;">
                    <children>
                        <Label text="SẮP HẾT HÀNG" textFill="#64748b">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Label>
                        <Label fx:id="lblSapHetHang" text="NaN" textFill="#ea580c">
                            <font>
                                <Font name="System Bold" size="25.0" />
                            </font>
                        </Label>
                        <Label text="Số mặt hàng sắp hết hàng" textFill="#94a3b8">
                            <font>
                                <Font size="12.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <VBox prefHeight="100.0" prefWidth="230.0" spacing="8.0" style="-fx-background-color: #ffffff; -fx-background-radius: 14; -fx-border-color: #fecaca; -fx-border-radius: 14; -fx-padding: 16;">
                    <children>
                        <Label text="GẦN HẾT HẠN" textFill="#64748b">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Label>
                        <Label fx:id="lblGanHetHan" text="NaN" textFill="#dc2626">
                            <font>
                                <Font name="System Bold" size="25.0" />
                            </font>
                        </Label>
                        <Label text="Số mặt hàng gần hết hạn" textFill="#94a3b8">
                            <font>
                                <Font size="12.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <VBox prefHeight="100.0" prefWidth="230.0" spacing="8.0" style="-fx-background-color: #ffffff; -fx-background-radius: 14; -fx-border-color: #fecaca; -fx-border-radius: 14; -fx-padding: 16;">
                    <children>
                        <Label text="HẾT HẠN" textFill="#64748b">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Label>
                        <Label fx:id="lblHetHan" text="NaN" textFill="#dc2626">
                            <font>
                                <Font name="System Bold" size="25.0" />
                            </font>
                        </Label>
                        <Label text="Số mặt hàng hết hạn" textFill="#94a3b8">
                            <font>
                                <Font size="12.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
            </children>
        </HBox>

        <!-- TOOLBAR -->
        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #ffffff; -fx-background-radius: 14; -fx-border-color: #e5e7eb; -fx-border-radius: 14; -fx-padding: 12;">
            <children>
                <TextField fx:id="txtSearch"
                           prefHeight="40.0"
                           prefWidth="320.0"
                           promptText="🔍  Tìm tên thuốc, đơn vị hoặc mô tả..."
                           style="-fx-background-color: #f8fafc; -fx-background-radius: 10; -fx-border-color: #cbd5e1; -fx-border-width: 1.2; -fx-border-radius: 10; -fx-text-fill: #0f172a; -fx-prompt-text-fill: #94a3b8; -fx-padding: 0 12 0 12;" />

                <Button fx:id="btnSearch"
                        mnemonicParsing="false"
                        onAction="#xuLyTimKiem"
                        prefHeight="40.0"
                        prefWidth="96.0"
                        text="Tìm kiếm"
                        textFill="#ffffff"
                        style="-fx-background-color: #2563eb; -fx-background-radius: 10; -fx-cursor: hand;">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>

                <Button fx:id="btnRefresh"
                        mnemonicParsing="false"
                        onAction="#xuLyLamMoi"
                        prefHeight="40.0"
                        prefWidth="92.0"
                        text="Làm mới"
                        textFill="#2563eb"
                        style="-fx-background-color: #eff6ff; -fx-background-radius: 10; -fx-border-color: #bfdbfe; -fx-border-radius: 10; -fx-cursor: hand;">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>

                <Region HBox.hgrow="ALWAYS" />

                <Button fx:id="btnThem"
                        mnemonicParsing="false"
                        onAction="#xuLyThem"
                        prefHeight="40.0"
                        prefWidth="112.0"
                        text="＋ Thêm mới"
                        textFill="#ffffff"
                        style="-fx-background-color: #16a34a; -fx-background-radius: 10; -fx-cursor: hand;">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>

                <Button fx:id="btnSua"
                        mnemonicParsing="false"
                        onAction="#xuLySua"
                        prefHeight="40.0"
                        prefWidth="100.0"
                        text="✎ Sửa"
                        textFill="#ffffff"
                        style="-fx-background-color: #f97316; -fx-background-radius: 10; -fx-cursor: hand;">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>

                <Button fx:id="btnXoa"
                        mnemonicParsing="false"
                        onAction="#xuLyXoa"
                        prefHeight="40.0"
                        prefWidth="90.0"
                        text="🗑 Xóa"
                        textFill="#ffffff"
                        style="-fx-background-color: #dc2626; -fx-background-radius: 10; -fx-cursor: hand;">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
            </children>
        </HBox>

        <!-- TABLE CARD -->
        <VBox spacing="10.0" VBox.vgrow="ALWAYS" style="-fx-background-color: #ffffff; -fx-background-radius: 16; -fx-border-color: #e5e7eb; -fx-border-radius: 16; -fx-padding: 12;">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="8.0">
                    <children>
                        <Label text="Danh sách thuốc" textFill="#0f172a">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>                        
                    </children>
                </HBox>

                <TableView fx:id="tableThuoc"
                           prefHeight="360.0"
                           style="-fx-background-color: #ffffff; -fx-control-inner-background: #ffffff; -fx-table-cell-border-color: #e5e7eb; -fx-border-color: transparent; -fx-text-background-color: #0f172a;"
                           VBox.vgrow="ALWAYS">
                    <placeholder>
                        <Label text="Không có thuốc trong danh sách" textFill="#94a3b8" />
                    </placeholder>
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="55.0" text="STT" />
                        <TableColumn fx:id="colTen" prefWidth="240.0" text="TÊN THUỐC" />
                        <TableColumn fx:id="colSoLuongTon" prefWidth="95.0" text="SỐ LƯỢNG" />
                        <TableColumn fx:id="colDonVi" prefWidth="80.0" text="ĐƠN VỊ" />
                        <TableColumn fx:id="colGiaNhap" prefWidth="110.0" text="GIÁ NHẬP" />
                        <TableColumn fx:id="colGiaBanSi" prefWidth="110.0" text="GIÁ BÁN SỈ" />
                        <TableColumn fx:id="colHanSuDung" prefWidth="120.0" text="HẠN SỬ DỤNG" />
                        <TableColumn fx:id="colMoTa" prefWidth="260.0" text="MÔ TẢ" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>
