<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox minHeight="420.0"
      prefHeight="650.0"
      prefWidth="850.0"
      spacing="10.0"
      style="-fx-background-color: #ffffff; -fx-background-radius: 14; -fx-padding: 14;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.PharmacyManagement.gui.controller.ChiTietToaNhapController">

    <children>
        <!-- HEADER -->
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="Chi tiết thuốc nhập" textFill="#0f172a">
                            <font><Font name="System Bold" size="18.0" /></font>
                        </Label>
                        <Label text="Danh sách thuốc sẽ được cộng vào kho sau khi xác nhận phiếu nhập" textFill="#64748b">
                            <font><Font size="12.0" /></font>
                        </Label>
                    </children>
                </VBox>
                <Label text="NHẬP KHO"
                       textFill="#16a34a"
                       style="-fx-background-color: #dcfce7; -fx-background-radius: 999; -fx-padding: 6 12 6 12;">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Label>
            </children>
        </HBox>

        <!-- TABLE CARD -->
        <VBox minHeight="320.0"
              spacing="0.0"
              style="-fx-background-color: #f8fafc; -fx-background-radius: 14; -fx-border-color: #e2e8f0; -fx-border-radius: 14; -fx-padding: 10;"
              VBox.vgrow="ALWAYS">
            <children>
                <TableView fx:id="tableChiTiet"
                           editable="true"
                           minHeight="300.0"
                           prefHeight="540.0"
                           prefWidth="100.0"
                           fixedCellSize="34.0"
                           style="-fx-background-color: #ffffff; -fx-control-inner-background: #ffffff; -fx-table-cell-border-color: #e5e7eb; -fx-border-color: transparent; -fx-text-background-color: #0f172a;"
                           VBox.vgrow="ALWAYS">
                    <placeholder>
                        <VBox alignment="CENTER" spacing="8.0">
                            <children>
                                <Label text="Chưa có thuốc nào trong phiếu nhập" textFill="#94a3b8" />
                                <Button mnemonicParsing="false"
                                        onAction="#xuLyThemDong"
                                        prefHeight="32.0"
                                        prefWidth="150.0"
                                        text="＋ Thêm dòng đầu tiên"
                                        textFill="#ffffff"
                                        style="-fx-background-color: #16a34a; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;" />
                            </children>
                        </VBox>
                    </placeholder>
                    <columns>
                        <TableColumn fx:id="colTenThuoc" prefWidth="290.0" text="TÊN THUỐC" />
                        <TableColumn fx:id="colSoLuong" prefWidth="100.0" text="SỐ LƯỢNG" />
                        <TableColumn fx:id="colDonVi" prefWidth="100.0" text="ĐƠN VỊ" />
                        <TableColumn fx:id="colDonGia" prefWidth="150.0" text="ĐƠN GIÁ NHẬP LẺ" />
                        <TableColumn fx:id="colHanSuDung" prefWidth="150.0" text="HẠN SỬ DỤNG" />
                        <TableColumn fx:id="colMoTa" prefWidth="260.0" text="MÔ TẢ" />
                        <TableColumn fx:id="colThaoTac" prefWidth="150.0" text="THAO TÁC" />
                    </columns>
                </TableView>
            </children>
        </VBox>

        <!-- FOOTER NOTE -->
        <HBox alignment="CENTER_LEFT"
              spacing="8.0"
              style="-fx-background-color: #eff6ff; -fx-background-radius: 12; -fx-border-color: #bfdbfe; -fx-border-radius: 12; -fx-padding: 8 10 8 10;">
            <children>
                <Label text="Gợi ý:" textFill="#1d4ed8">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Label>
                <Label text="Nếu tên thuốc và đơn vị đã tồn tại, hệ thống cộng số lượng vào tồn kho; nếu khác đơn vị, tạo mặt hàng mới."
                       textFill="#475569"
                       wrapText="true"
                       HBox.hgrow="ALWAYS">
                    <font><Font size="12.0" /></font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
            </children>
        </HBox>
    </children>
</VBox>
