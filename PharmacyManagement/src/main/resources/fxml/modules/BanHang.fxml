<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="rootBanHang"
      prefHeight="750.0"
      prefWidth="1200.0"
      spacing="18.0"
      style="-fx-background-color: #f4f7fb; -fx-padding: 24;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.PharmacyManagement.gui.controller.BanHangController">

    <children>
        <!-- HEADER -->
        <HBox alignment="CENTER_LEFT" spacing="16.0">
            <children>
                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="XUẤT TOA BÁN HÀNG" textFill="#1d4ed8">
                            <font>
                                <Font name="System Bold" size="26.0" />
                            </font>
                        </Label>
                        <Label text="Tạo toa, chọn khách hàng, thêm thuốc và thanh toán hóa đơn" textFill="#64748b">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <Button fx:id="btnThanhToan"
                        mnemonicParsing="false"
                        onAction="#xuLyThanhToan"
                        prefHeight="44.0"
                        prefWidth="150.0"
                        text="Thanh toán"
                        textFill="WHITE"
                        style="-fx-background-color: #2563eb; -fx-background-radius: 11; -fx-cursor: hand; -fx-font-weight: bold; -fx-effect: dropshadow(gaussian, rgba(37,99,235,0.25), 12, 0, 0, 4);">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>
            </children>
        </HBox>

        <!-- QUICK ACTION BAR -->
        <HBox alignment="CENTER_LEFT" spacing="12.0"
              style="-fx-background-color: #ffffff; -fx-background-radius: 16; -fx-border-color: #dbeafe; -fx-border-radius: 16; -fx-padding: 14; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.06), 14, 0, 0, 5);">
            <children>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Khách hàng" textFill="#475569">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Label>
                        <ComboBox fx:id="cbKhachHang"
                                  promptText="Chọn khách hàng..."
                                  prefHeight="39.0"
                                  prefWidth="280.0"
                                  style="-fx-background-color: #f8fafc; -fx-background-radius: 10; -fx-border-color: #cbd5e1; -fx-border-radius: 10; -fx-border-width: 1; -fx-font-size: 13px;" />
                    </children>
                </VBox>

                <Button fx:id="btnTaoToa"
                        mnemonicParsing="false"
                        onAction="#xuLyTaoToaMoi"
                        prefHeight="39.0"
                        prefWidth="145.0"
                        text="+ Tạo toa mới"
                        textFill="WHITE"
                        style="-fx-background-color: #16a34a; -fx-background-radius: 10; -fx-cursor: hand; -fx-font-weight: bold;" />

                <Button fx:id="btnXoaChiTiet"
                        mnemonicParsing="false"
                        onAction="#xuLyXoaChiTiet"
                        prefHeight="39.0"
                        prefWidth="155.0"
                        text="Xóa thuốc chọn"
                        textFill="WHITE"
                        style="-fx-background-color: #ef4444; -fx-background-radius: 10; -fx-cursor: hand; -fx-font-weight: bold;" />

                <Region HBox.hgrow="ALWAYS" />

                <VBox alignment="CENTER_RIGHT" spacing="3.0">
                    <children>
                        <Label text="Gợi ý thao tác" textFill="#64748b">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Label>
                        <Label text="Nhấp đúp thuốc trong kho để thêm vào toa" textFill="#94a3b8">
                            <font>
                                <Font size="12.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
            </children>
        </HBox>

        <!-- MAIN CONTENT -->
        <SplitPane dividerPositions="0.52"
                   style="-fx-background-color: transparent; -fx-box-border: transparent;"
                   VBox.vgrow="ALWAYS">
            <items>
                <!-- LEFT CARD: TOA DANG CHO -->
                <VBox spacing="12.0"
                      style="-fx-background-color: #ffffff; -fx-background-radius: 18; -fx-border-color: #e2e8f0; -fx-border-radius: 18; -fx-padding: 16; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.06), 14, 0, 0, 5);">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Toa thuốc đang chờ" textFill="#0f172a">
                                            <font>
                                                <Font name="System Bold" size="17.0" />
                                            </font>
                                        </Label>
                                        <Label text="Mỗi tab là một toa/hóa đơn riêng" textFill="#64748b">
                                            <font>
                                                <Font size="12.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                                <Label text="Đang xử lý" textFill="#2563eb"
                                       style="-fx-background-color: #eff6ff; -fx-background-radius: 999; -fx-padding: 6 12 6 12; -fx-font-weight: bold;" />
                            </children>
                        </HBox>

                        <TabPane fx:id="tabPane"
                                 tabClosingPolicy="ALL_TABS"
                                 style="-fx-background-color: #f8fafc; -fx-background-radius: 14; -fx-border-color: #e2e8f0; -fx-border-radius: 14;"
                                 VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>

                <!-- RIGHT CARD: THUOC TRONG KHO -->
                <VBox spacing="12.0"
                      style="-fx-background-color: #ffffff; -fx-background-radius: 18; -fx-border-color: #e2e8f0; -fx-border-radius: 18; -fx-padding: 16; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.06), 14, 0, 0, 5);">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Danh mục thuốc trong kho" textFill="#0f172a">
                                            <font>
                                                <Font name="System Bold" size="17.0" />
                                            </font>
                                        </Label>
                                        <Label text="Tìm thuốc và nhấp đúp để thêm vào toa" textFill="#64748b">
                                            <font>
                                                <Font size="12.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <TextField fx:id="txtSearchThuoc"
                                   prefHeight="124.0"
                                   promptText="🔍  Nhập tên thuốc..."
                                   style="-fx-background-color: #f8fafc; 
                                   -fx-background-radius: 10; 
                                   -fx-border-color: #cbd5e1; 
                                   -fx-border-radius: 10; -fx-text-fill: #0f172a; 
                                   -fx-prompt-text-fill: #94a3b8; -fx-padding: 0 12 0 12;" />

                        <TableView fx:id="tableThuoc"
                                   style="-fx-background-color: #ffffff; -fx-control-inner-background: #ffffff; -fx-table-cell-border-color: #e5e7eb; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-background-radius: 12; -fx-text-background-color: #0f172a;"
                                   VBox.vgrow="ALWAYS">
                            <placeholder>
                                <Label text="Không có thuốc trong kho" textFill="#94a3b8" />
                            </placeholder>
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="50.0" text="STT" />
                                <TableColumn fx:id="colTen" prefWidth="190.0" text="Tên thuốc" />
                                <TableColumn fx:id="colSoLuongTon" prefWidth="78.0" text="SL" />
                                <TableColumn fx:id="colDonVi" prefWidth="70.0" text="Đơn vị" />
                                <TableColumn fx:id="colGiaNhap" prefWidth="95.0" text="Giá nhập" />
                                <TableColumn fx:id="colGiaBanSi" prefWidth="95.0" text="Giá bán" />
                                <TableColumn fx:id="colHanSuDung" prefWidth="110.0" text="Hạn sử dụng" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>
            </items>
        </SplitPane>
    </children>
</VBox>
