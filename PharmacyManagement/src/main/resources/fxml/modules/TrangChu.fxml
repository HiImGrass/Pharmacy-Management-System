<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true"
            hbarPolicy="NEVER"
            prefHeight="650.0"
            prefWidth="950.0"
            style="-fx-background: #f4f7fb; -fx-background-color: #f4f7fb;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.PharmacyManagement.gui.controller.TrangChuController">

    <content>
        <VBox spacing="22.0" style="-fx-background-color: #f4f7fb; -fx-padding: 26;">
            <children>

            <!-- HERO / WELCOME -->
            <VBox spacing="14.0"
                minHeight="200.0"
                prefHeight="200.0"
                maxWidth="Infinity"
                style="-fx-background-color: linear-gradient(to right, #1d4ed8, #2563eb, #38bdf8);
                        -fx-background-radius: 22;
                        -fx-padding: 28 34 28 34;">

                <children>
                    <HBox alignment="CENTER_LEFT"
                        spacing="18.0"
                        minHeight="100.0"
                        maxWidth="Infinity">

                        <children>
                            <VBox spacing="10.0"
                                minHeight="90.0"
                                maxWidth="Infinity"
                                HBox.hgrow="ALWAYS">

                                <children>
                                    <Label text="QUẢN LÝ NHÀ THUỐC"
                                        minHeight="42.0"
                                        maxWidth="Infinity"
                                        textFill="#ffffff"
                                        style="-fx-text-fill: #ffffff;
                                                -fx-font-size: 30px;
                                                -fx-font-weight: bold;" />

                                    <Label text="Theo dõi bán hàng, nhập kho, khách hàng và tồn kho trong một màn hình"
                                        minHeight="26.0"
                                        maxWidth="Infinity"
                                        wrapText="true"
                                        textFill="#eff6ff"
                                        style="-fx-text-fill: #eff6ff;
                                                -fx-font-size: 14px;
                                                -fx-font-weight: bold;" />
                                </children>
                            </VBox>

                            <VBox alignment="CENTER"
                                minHeight="82.0"
                                minWidth="82.0"
                                prefHeight="82.0"
                                prefWidth="82.0"
                                maxHeight="82.0"
                                maxWidth="82.0"
                                style="-fx-background-color: rgba(255,255,255,0.18);
                                        -fx-background-radius: 22;
                                        -fx-border-color: rgba(255,255,255,0.35);
                                        -fx-border-radius: 22;
                                        -fx-border-width: 1;">

                                <children>
                                    <Label text="✚"
                                        textFill="#ffffff"
                                        style="-fx-text-fill: #ffffff;
                                                -fx-font-size: 34px;
                                                -fx-font-weight: bold;" />
                                </children>
                            </VBox>
                        </children>
                    </HBox>

                    <HBox spacing="10.0"
                        minHeight="38.0">
                        <children>
                            <Label text="Trạng thái: Đang hoạt động"
                                minHeight="30.0"
                                textFill="#ffffff"
                                style="-fx-background-color: rgba(22,163,74,0.35);
                                        -fx-background-radius: 999;
                                        -fx-padding: 7 13 7 13;
                                        -fx-text-fill: #ffffff;
                                        -fx-font-size: 12.5px;
                                        -fx-font-weight: bold;" />

                            <Label text="Dữ liệu lưu trên máy người dùng"
                                minHeight="30.0"
                                textFill="#ffffff"
                                style="-fx-background-color: rgba(255,255,255,0.18);
                                        -fx-background-radius: 999;
                                        -fx-padding: 7 13 7 13;
                                        -fx-text-fill: #ffffff;
                                        -fx-font-size: 12.5px;
                                        -fx-font-weight: bold;" />
                        </children>
                    </HBox>
                </children>
            </VBox>

            <!-- SUMMARY CARDS -->
            <HBox spacing="16.0">
                <children>
                    <VBox prefHeight="112.0" spacing="9.0" HBox.hgrow="ALWAYS"
                            style="-fx-background-color: #ffffff; -fx-background-radius: 18; -fx-border-color: #dbeafe; -fx-border-radius: 18; -fx-padding: 18;">
                        <children>
                            <HBox alignment="CENTER_LEFT" spacing="10.0">
                                <children>
                                    <Label text="🧾" style="-fx-background-color: #dbeafe; -fx-background-radius: 12; -fx-padding: 7;" />
                                    <Label text="HÓA ĐƠN HÔM NAY" textFill="#64748b">
                                        <font><Font name="System Bold" size="12.0" /></font>
                                    </Label>
                                </children>
                            </HBox>
                            <Label fx:id="lblHoaDonHomNay" text="NaN" textFill="#0f172a">
                                <font><Font name="System Bold" size="28.0" /></font>
                            </Label>
                            <Label text="Số hóa đơn đã xuất trong ngày" textFill="#94a3b8">
                                <font><Font size="12.0" /></font>
                            </Label>
                        </children>
                    </VBox>

                    <VBox prefHeight="112.0" spacing="9.0" HBox.hgrow="ALWAYS"
                            style="-fx-background-color: #ffffff; -fx-background-radius: 18; -fx-border-color: #dcfce7; -fx-border-radius: 18; -fx-padding: 18;">
                        <children>
                            <HBox alignment="CENTER_LEFT" spacing="10.0">
                                <children>
                                    <Label text="💰" style="-fx-background-color: #dcfce7; -fx-background-radius: 12; -fx-padding: 7;" />
                                    <Label text="DOANH THU" textFill="#64748b">
                                        <font><Font name="System Bold" size="12.0" /></font>
                                    </Label>
                                </children>
                            </HBox>
                            <Label fx:id="lblDoanhThuHomNay" text="NaN đ" textFill="#16a34a">
                                <font><Font name="System Bold" size="26.0" /></font>
                            </Label>
                            <Label text="Tổng tiền bán trong ngày" textFill="#94a3b8">
                                <font><Font size="12.0" /></font>
                            </Label>
                        </children>
                    </VBox>

                    <VBox prefHeight="112.0" spacing="9.0" HBox.hgrow="ALWAYS"
                            style="-fx-background-color: #ffffff; -fx-background-radius: 18; -fx-border-color: #fef3c7; -fx-border-radius: 18; -fx-padding: 18;">
                        <children>
                            <HBox alignment="CENTER_LEFT" spacing="10.0">
                                <children>
                                    <Label text="📦" style="-fx-background-color: #fef3c7; -fx-background-radius: 12; -fx-padding: 7;" />
                                    <Label text="TỒN KHO THẤP" textFill="#64748b">
                                        <font><Font name="System Bold" size="12.0" /></font>
                                    </Label>
                                </children>
                            </HBox>
                            <Label fx:id="lblTonKhoThap" text="NaN" textFill="#d97706">
                                <font><Font name="System Bold" size="28.0" /></font>
                            </Label>
                            <Label text="Mặt hàng cần nhập thêm" textFill="#94a3b8">
                                <font><Font size="12.0" /></font>
                            </Label>
                        </children>
                    </VBox>

                    <VBox prefHeight="112.0" spacing="9.0" HBox.hgrow="ALWAYS"
                            style="-fx-background-color: #ffffff; -fx-background-radius: 18; -fx-border-color: #fef3c7; -fx-border-radius: 18; -fx-padding: 18;">
                        <children>
                            <HBox alignment="CENTER_LEFT" spacing="10.0">
                                <children>
                                    <Label text="⏳" style="-fx-background-color: #fee2e2; -fx-background-radius: 12; -fx-padding: 7;" />
                                    <Label text="GẦN HẾT HẠN" textFill="#64748b">
                                        <font><Font name="System Bold" size="12.0" /></font>
                                    </Label>
                                </children>
                            </HBox>
                            <Label fx:id="lblGanHetHan" text="NaN" textFill="#dc2626">
                                <font><Font name="System Bold" size="28.0" /></font>
                            </Label>
                            <Label text="Thuốc cần kiểm tra hạn dùng" textFill="#94a3b8">
                                <font><Font size="12.0" /></font>
                            </Label>
                        </children>
                    </VBox>
                    
                    <VBox prefHeight="112.0" spacing="9.0" HBox.hgrow="ALWAYS"
                            style="-fx-background-color: #ffffff; -fx-background-radius: 18; -fx-border-color: #fee2e2; -fx-border-radius: 18; -fx-padding: 18;">
                        <children>
                            <HBox alignment="CENTER_LEFT" spacing="10.0">
                                <children>
                                    <Label text="⛔" style="-fx-background-color: #fee2e2; -fx-background-radius: 12; -fx-padding: 7;" />
                                    <Label text="HẾT HẠN" textFill="#64748b">
                                        <font><Font name="System Bold" size="12.0" /></font>
                                    </Label>
                                </children>
                            </HBox>
                            <Label fx:id="lblHetHan" text="NaN" textFill="#dc2626">
                                <font><Font name="System Bold" size="28.0" /></font>
                            </Label>
                            <Label text="Thuốc đã hết hạn sử dụng" textFill="#94a3b8">
                                <font><Font size="12.0" /></font>
                            </Label>
                        </children>
                    </VBox>
                </children>
            </HBox>

            <!-- BODY -->
            <HBox spacing="18.0" VBox.vgrow="ALWAYS">
                <children>
                    <!-- QUICK ACTIONS -->
                    <VBox spacing="14.0" HBox.hgrow="ALWAYS"
                            style="-fx-background-color: #ffffff; -fx-background-radius: 20; -fx-border-color: #e5e7eb; -fx-border-radius: 20; -fx-padding: 20;">
                        <children>
                            <HBox alignment="CENTER_LEFT">
                                <children>
                                    <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                        <children>
                                            <Label text="Thao tác nhanh" textFill="#0f172a">
                                                <font><Font name="System Bold" size="18.0" /></font>
                                            </Label>
                                            <Label text="Các chức năng thường dùng trong quầy thuốc" textFill="#64748b">
                                                <font><Font size="12.5" /></font>
                                            </Label>
                                        </children>
                                    </VBox>
                                </children>
                            </HBox>

                            <Separator style="-fx-background-color: #e5e7eb;" />

                            <HBox spacing="14.0">
                                <children>
                                    <VBox spacing="12.0" HBox.hgrow="ALWAYS">
                                        <children>
                                            <Button fx:id="btnQuickBanHang" 
                                                    mnemonicParsing="false"
                                                    prefHeight="58.0"
                                                    maxWidth="Infinity"
                                                    text="🛒  Xuất toa / Bán hàng"
                                                    onAction="#handleQuickNavigation"
                                                    textFill="#ffffff"
                                                    style="-fx-background-color: #2563eb; -fx-background-radius: 14; -fx-cursor: hand; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 0 18 0 18;" />

                                            <Button fx:id="btnQuickNhapHang"
                                                    mnemonicParsing="false"
                                                    prefHeight="58.0"
                                                    maxWidth="Infinity"
                                                    text="📥  Nhập hàng vào kho"
                                                    onAction="#handleQuickNavigation"
                                                    textFill="#ffffff"
                                                    style="-fx-background-color: #16a34a; -fx-background-radius: 14; -fx-cursor: hand; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 0 18 0 18;" />

                                            <Button fx:id="btnQuickQuanLyThuoc"
                                                    mnemonicParsing="false"
                                                    prefHeight="58.0"
                                                    maxWidth="Infinity"
                                                    text="💊  Quản lý thuốc"
                                                    onAction="#handleQuickNavigation"
                                                    textFill="#0f172a"
                                                    style="-fx-background-color: #e0f2fe; -fx-background-radius: 14; -fx-border-color: #bae6fd; -fx-border-radius: 14; -fx-cursor: hand; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 0 18 0 18;" />
                                        </children>
                                    </VBox>

                                    <VBox spacing="12.0" HBox.hgrow="ALWAYS">
                                        <children>
                                            <Button fx:id="btnQuickKhachHang"
                                                    mnemonicParsing="false"
                                                    prefHeight="58.0"
                                                    maxWidth="Infinity"
                                                    text="👤  Quản lý khách hàng"
                                                    onAction="#handleQuickNavigation"
                                                    textFill="#0f172a"
                                                    style="-fx-background-color: #f0fdf4; -fx-background-radius: 14; -fx-border-color: #bbf7d0; -fx-border-radius: 14; -fx-cursor: hand; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 0 18 0 18;" />

                                            <Button fx:id="btnQuickLichSuBan"
                                                    mnemonicParsing="false"
                                                    prefHeight="58.0"
                                                    maxWidth="Infinity"
                                                    text="📑  Lịch sử bán hàng"
                                                    onAction="#handleQuickNavigation"
                                                    textFill="#0f172a"
                                                    style="-fx-background-color: #fefce8; -fx-background-radius: 14; -fx-border-color: #fde68a; -fx-border-radius: 14; -fx-cursor: hand; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 0 18 0 18;" />

                                            <Button fx:id="btnQuickLichSuNhap"
                                                    mnemonicParsing="false"
                                                    prefHeight="58.0"
                                                    maxWidth="Infinity"
                                                    text="📋  Lịch sử nhập hàng"
                                                    onAction="#handleQuickNavigation"
                                                    textFill="#0f172a"
                                                    style="-fx-background-color: #fff7ed; -fx-background-radius: 14; -fx-border-color: #fed7aa; -fx-border-radius: 14; -fx-cursor: hand; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 0 18 0 18;" />
                                        </children>
                                    </VBox>
                                </children>
                            </HBox>
                        </children>
                    </VBox>

                    <!-- RIGHT PANEL -->
                    <VBox prefWidth="285.0" spacing="16.0">
                        <children>
                            <VBox spacing="12.0"
                                    style="-fx-background-color: #ffffff; -fx-background-radius: 20; -fx-border-color: #e5e7eb; -fx-border-radius: 20; -fx-padding: 20;">
                                <children>
                                    <Label text="Tình trạng hệ thống" textFill="#0f172a">
                                        <font><Font name="System Bold" size="17.0" /></font>
                                    </Label>

                                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                                        <children>
                                            <Label text="●" textFill="#16a34a">
                                                <font><Font size="18.0" /></font>
                                            </Label>
                                            <VBox spacing="2.0">
                                                <children>
                                                    <Label text="Ứng dụng sẵn sàng" textFill="#0f172a">
                                                        <font><Font name="System Bold" size="13.0" /></font>
                                                    </Label>
                                                    <Label text="Có thể bán hàng và nhập kho" textFill="#64748b">
                                                        <font><Font size="11.5" /></font>
                                                    </Label>
                                                </children>
                                            </VBox>
                                        </children>
                                    </HBox>

                                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                                        <children>
                                            <Label text="●" textFill="#2563eb">
                                                <font><Font size="18.0" /></font>
                                            </Label>
                                            <VBox spacing="2.0">
                                                <children>
                                                    <Label text="Dữ liệu nội bộ" textFill="#0f172a">
                                                        <font><Font name="System Bold" size="13.0" /></font>
                                                    </Label>
                                                    <Label text="Lưu và xử lý trên máy" textFill="#64748b">
                                                        <font><Font size="11.5" /></font>
                                                    </Label>
                                                </children>
                                            </VBox>
                                        </children>
                                    </HBox>
                                </children>
                            </VBox>

                            <VBox spacing="12.0"
                                    style="-fx-background-color: #ffffff; -fx-background-radius: 20; -fx-border-color: #e5e7eb; -fx-border-radius: 20; -fx-padding: 20;">
                                <children>
                                    <Label text="Ghi nhớ nhanh" textFill="#0f172a">
                                        <font><Font name="System Bold" size="17.0" /></font>
                                    </Label>

                                    <Label text="• Kiểm tra tồn kho trước khi bán"
                                            textFill="#475569"
                                            wrapText="true">
                                        <font><Font size="12.5" /></font>
                                    </Label>
                                    <Label text="• Cập nhật thuốc gần hết hạn"
                                            textFill="#475569"
                                            wrapText="true">
                                        <font><Font size="12.5" /></font>
                                    </Label>
                                    <Label text="• Sao lưu dữ liệu định kỳ"
                                            textFill="#475569"
                                            wrapText="true">
                                        <font><Font size="12.5" /></font>
                                    </Label>
                                </children>
                            </VBox>
                        </children>
                    </VBox>
                </children>
            </HBox>

            <Region prefHeight="4.0" />
            </children>
        </VBox>
    </content>
</ScrollPane>
