<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="260.0"
      spacing="12.0"
      style="-fx-background-color: linear-gradient(to bottom, #0f172a, #1e3a8a); -fx-padding: 18 16 18 16;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.PharmacyManagement.gui.controller.sidebar.SidebarController">

    <children>
        <!-- BRAND -->
        <HBox alignment="CENTER_LEFT" spacing="12.0" style="-fx-padding: 4 2 14 2;">
            <children>
                <Label text="✚"
                       alignment="CENTER"
                       prefHeight="46.0"
                       prefWidth="46.0"
                       style="
                       -fx-background-color: rgba(255,255,255,0.16); 
                       -fx-background-radius: 14; 
                       -fx-border-color: rgba(255,255,255,0.22); 
                       -fx-border-radius: 14;
                       -fx-text-fill: #ffffff;">
                    <font>
                        <Font size="23.0" />
                    </font>
                </Label>
                <VBox spacing="2.0">
                    <children>
                        <Label text="NHÀ THUỐC" textFill="#ffffff">
                            <font>
                                <Font name="System Bold" size="19.0" />
                            </font>
                        </Label>
                        <Label text="Quản lý bán thuốc" textFill="#bfdbfe">
                            <font>
                                <Font size="12.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
            </children>
        </HBox>

        <Separator opacity="0.18" />

        <!-- TỔNG QUAN -->
        <Label text="TỔNG QUAN" textFill="#93c5fd" style="-fx-padding: 8 0 0 6;">
            <font>
                <Font name="System Bold" size="11.0" />
            </font>
        </Label>

        <Button fx:id="btnTrangChu"
                alignment="CENTER_LEFT"
                mnemonicParsing="false"
                onAction="#handleNavigation"
                prefHeight="44.0"
                prefWidth="228.0"
                text="🏠  Trang Chủ"
                textFill="#ffffff"
                style="-fx-background-color: #2563eb; -fx-background-radius: 12; -fx-cursor: hand; -fx-padding: 0 0 0 14;">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Button>

        <!-- QUẢN LÝ -->
        <Label text="QUẢN LÝ" textFill="#93c5fd" style="-fx-padding: 8 0 0 6;">
            <font>
                <Font name="System Bold" size="11.0" />
            </font>
        </Label>

        <Button fx:id="btnKhachHang"
                alignment="CENTER_LEFT"
                mnemonicParsing="false"
                onAction="#handleNavigation"
                prefHeight="42.0"
                prefWidth="228.0"
                text="👤  Khách Hàng"
                textFill="#e0f2fe"
                style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 0 0 0 14;">
            <font>
                <Font name="System Bold" size="13.0" />
            </font>
        </Button>

        <Button fx:id="btnQuanLyThuoc"
                alignment="CENTER_LEFT"
                mnemonicParsing="false"
                onAction="#handleNavigation"
                prefHeight="42.0"
                prefWidth="228.0"
                text="💊  Quản Lý Thuốc"
                textFill="#e0f2fe"
                style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 0 0 0 14;">
            <font>
                <Font name="System Bold" size="13.0" />
            </font>
        </Button>

        <!-- NGHIỆP VỤ -->
        <Label text="NGHIỆP VỤ" textFill="#93c5fd" style="-fx-padding: 8 0 0 6;">
            <font>
                <Font name="System Bold" size="11.0" />
            </font>
        </Label>

        <Button fx:id="btnBanHang"
                alignment="CENTER_LEFT"
                mnemonicParsing="false"
                onAction="#handleNavigation"
                prefHeight="42.0"
                prefWidth="228.0"
                text="⚡  Xuất Toa (Bán)"
                textFill="#e0f2fe"
                style="-fx-background-color: rgba(255,255,255,0.07); -fx-background-radius: 12; -fx-border-color: rgba(255,255,255,0.10); -fx-border-radius: 12; -fx-cursor: hand; -fx-padding: 0 0 0 14;">
            <font>
                <Font name="System Bold" size="13.0" />
            </font>
        </Button>

        <Button fx:id="btnNhapHang"
                alignment="CENTER_LEFT"
                mnemonicParsing="false"
                onAction="#handleNavigation"
                prefHeight="42.0"
                prefWidth="228.0"
                text="📥  Nhập Toa (Nhập)"
                textFill="#e0f2fe"
                style="-fx-background-color: rgba(255,255,255,0.07); -fx-background-radius: 12; -fx-border-color: rgba(255,255,255,0.10); -fx-border-radius: 12; -fx-cursor: hand; -fx-padding: 0 0 0 14;">
            <font>
                <Font name="System Bold" size="13.0" />
            </font>
        </Button>

        <!-- LỊCH SỬ -->
        <Label text="LỊCH SỬ" textFill="#93c5fd" style="-fx-padding: 8 0 0 6;">
            <font>
                <Font name="System Bold" size="11.0" />
            </font>
        </Label>

        <Button fx:id="btnLichSuBanHang"
                alignment="CENTER_LEFT"
                mnemonicParsing="false"
                onAction="#handleNavigation"
                prefHeight="42.0"
                prefWidth="228.0"
                text="📜  Lịch Sử Bán Hàng"
                textFill="#e0f2fe"
                style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 0 0 0 14;">
            <font>
                <Font name="System Bold" size="13.0" />
            </font>
        </Button>

        <Button fx:id="btnLichSuNhapHang"
                alignment="CENTER_LEFT"
                mnemonicParsing="false"
                onAction="#handleNavigation"
                prefHeight="42.0"
                prefWidth="228.0"
                text="📦  Lịch Sử Nhập Hàng"
                textFill="#e0f2fe"
                style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 0 0 0 14;">
            <font>
                <Font name="System Bold" size="13.0" />
            </font>
        </Button>

    </children>
</VBox>
