spring.datasource.url=jdbc:mysql://localhost:3306/{DATABASE-NAME-HERE}?allowPublicKeyRetrieval=true&sslMode=DISABLED&serverTimezone=Asia/Ho_Chi_Minh
spring.datasource.username=root
spring.datasource.password=YOUR-MYSQL-WORKBENCH-PASSWORD
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true

spring.sql.init.mode=always
